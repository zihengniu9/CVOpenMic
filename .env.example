# Copy this file to .env and keep the real key out of Git and Docker images.
# The redacted resume/JD text is sent to this DeepSeek-compatible endpoint.
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=45
DEEPSEEK_MAX_RETRIES=2

# This is a per-browser-session guard, not a replacement for gateway rate limiting.
MAX_LLM_CALLS_PER_SESSION=12
